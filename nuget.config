<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      <clear/> is deliberate. It locks `dotnet restore` to nuget.org and
      prevents a contributor's machine-level NuGet config from pulling
      from a private feed or a typo-squatted public mirror.
      Add a feed below only after a security review.
    -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
