# Wick — example environment for the MCP server.
# Copy to .env and source before running: `set -a && source .env && set +a`
# (see docs/getting-started.md for the AI-client config form of these same variables)

# Comma-separated list of tool pillars to activate.
# Options: core | runtime | csharp | build | scene | all
# Default in code: core
WICK_GROUPS=core,runtime,csharp,build

# Absolute path to the Godot 4.6.1+ mono/.NET binary.
# Required for the `runtime` pillar (game launching, exception capture).
# Linux example:   /opt/godot/Godot_v4.6.1-stable_mono_linux.x86_64
# macOS example:   /Applications/Godot_mono.app/Contents/MacOS/Godot
# Windows example: C:\Tools\Godot_v4.6.1-stable_mono_win64.exe
WICK_GODOT_BIN=

# Absolute path to the Godot project directory containing project.godot.
# Defaults to the current working directory.
WICK_PROJECT_PATH=

# OPTIONAL: Verbose JSON-RPC tracing for protocol debugging.
# Default off. Set to "verbose" only when debugging the wire protocol.
# WARNING: when enabled, every JSON-RPC frame (including textDocument/didOpen
# payloads with FULL FILE CONTENTS) is written to stderr.
# WICK_RPC_TRACE=

# OPTIONAL: Override the in-process Wick.Runtime bridge port.
# Default 7878. Used by the optional Wick.Runtime companion only.
# WICK_RUNTIME_PORT=
